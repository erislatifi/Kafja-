{
  "name": "kafe-nlagje-desktop",
  "version": "1.0.0",
  "description": "Kafe Nlagje Desktop App - Powered by PRO IT",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "build:mac": "electron-builder --mac"
  },
  "devDependencies": {
    "electron": "^32.1.2",
    "electron-builder": "^25.0.5"
  },
  "build": {
    "appId": "com.proit.kafenlagje",
    "productName": "Kafe Nlagje",
    "directories": { "output": "../dist-electron" },
    "win": { "target": "nsis", "icon": "icon.ico" },
    "linux": { "target": "AppImage", "icon": "icon.png" },
    "mac": { "target": "dmg", "icon": "icon.icns" }
  }
}
