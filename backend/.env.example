# KOPJOJE kete file si ".env" dhe plotesoji vlerat e tua

# ---- DATABAZA ----
# Formati: postgresql://USERNAME:PASSWORD@HOST:PORT/DATABASE_NAME
DATABASE_URL="postgresql://kafe_user:fjalekalim_i_forte@localhost:5432/kafe_nlagje_db?schema=public"

# ---- SERVER ----
PORT=4000
NODE_ENV=production

# ---- JWT (SIGURI) ----
# GJENERO nje string te gjate dhe rastesishem per prodhim (shih docs/INSTALIMI.md)
JWT_SECRET="ndrysho_kete_me_nje_string_te_gjate_rastesishem_64_karaktere"
JWT_EXPIRES_IN="12h"

# ---- CORS (cilet domain lejohen te lidhen me API) ----
FRONTEND_URL="https://app.prs-ks.com"

# ---- BRANDING ----
BIZNESI_EMRI="Kafe Nlagje"
BIZNESI_FOOTER="Powered by PRO IT | prs-ks.com"
