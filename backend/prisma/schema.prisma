generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ------------------------------------------------------------
// ENUMS
// ------------------------------------------------------------

enum Role {
  ADMIN
  MENAXHER
  ARKATAR
  KAMERIER
}

enum Unit {
  COPE // copë
  KG
  LITER
  GRAM
  ML
}

enum StockMovementType {
  HYRJE // shtim stoku (blerje)
  SHITJE // zbritje nga shitja
  KORRIGJIM // korrigjim manual
  HUMBJE // produkt i prishur/humbur
}

enum OrderStatus {
  AKTIVE
  PERFUNDUAR
  ANULUAR
}

enum PrinterConnectionType {
  USB
  NETWORK
}

// ------------------------------------------------------------
// USERS & AUTH
// ------------------------------------------------------------

model User {
  id           String   @id @default(uuid())
  emri         String
  username     String   @unique
  password     String // hashed me bcrypt
  role         Role     @default(KAMERIER)
  pin          String?  // PIN 4-shifror per kycje me tastiere
  rfidKod      String?  @unique // Kodi unik i karteles RFID/NFC
  aktiv        Boolean  @default(true)
  krijuarMe    DateTime @default(now())
  perditesuarMe DateTime @updatedAt

  porosite     Order[]
  levizjetStokut StockMovement[]

  @@map("users")
}

// ------------------------------------------------------------
// PRODUCTS & CATEGORIES
// ------------------------------------------------------------

model Category {
  id        String    @id @default(uuid())
  emri      String    @unique
  ikona     String?   // emoji ose kod ikone per UI
  radhitja  Int       @default(0)
  produktet Product[]

  @@map("categories")
}

model Product {
  id              String   @id @default(uuid())
  emri            String
  categoryId      String
  category        Category @relation(fields: [categoryId], references: [id])

  cmimiShitjes    Decimal  @db.Decimal(10, 2)
  cmimiBlerjes    Decimal? @db.Decimal(10, 2) // opsional, per llogaritje fitimi

  sasiaStok       Decimal  @default(0) @db.Decimal(10, 3)
  njesia          Unit     @default(COPE)
  alarmStokuMin   Decimal  @default(5) @db.Decimal(10, 3) // niveli i alarmit

  barkod          String?  @unique
  aktiv           Boolean  @default(true)

  krijuarMe       DateTime @default(now())
  perditesuarMe   DateTime @updatedAt

  orderItems      OrderItem[]
  levizjetStokut  StockMovement[]

  @@index([categoryId])
  @@index([barkod])
  @@map("products")
}

// ------------------------------------------------------------
// STOCK MOVEMENTS (historia e plote e levizjeve)
// ------------------------------------------------------------

model StockMovement {
  id          String            @id @default(uuid())
  productId   String
  product     Product           @relation(fields: [productId], references: [id])

  lloji       StockMovementType
  sasia       Decimal           @db.Decimal(10, 3) // pozitive per hyrje, negative per shitje/humbje
  sasiaPara   Decimal           @db.Decimal(10, 3) // stoku para levizjes
  sasiaPas    Decimal           @db.Decimal(10, 3) // stoku pas levizjes

  shenim      String?
  userId      String?
  user        User?             @relation(fields: [userId], references: [id])

  orderId     String?           // nese eshte rrjedhoje e nje porosie
  order       Order?            @relation(fields: [orderId], references: [id])

  krijuarMe   DateTime          @default(now())

  @@index([productId])
  @@index([krijuarMe])
  @@map("stock_movements")
}

// ------------------------------------------------------------
// ORDERS (POS)
// ------------------------------------------------------------

model Order {
  id            String      @id @default(uuid())
  numriPorosise Int         @unique @default(autoincrement())

  userId        String
  user          User        @relation(fields: [userId], references: [id])

  status        OrderStatus @default(PERFUNDUAR)
  totali        Decimal     @db.Decimal(10, 2)

  tavolinaNr    Int?        // per modulin opsional te tavolinave (e ardhshme)

  metodaPageses String?   // cash | card
  printuarMe    DateTime?   // kur eshte printuar per here te pare
  numriPrintimeve Int       @default(0)

  krijuarMe     DateTime    @default(now())

  items         OrderItem[]
  levizjetStokut StockMovement[]

  @@index([userId])
  @@index([krijuarMe])
  @@map("orders")
}

model OrderItem {
  id          String   @id @default(uuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId   String
  product     Product  @relation(fields: [productId], references: [id])

  emriProduktit String  // snapshot i emrit ne kohen e shitjes (mbrohet nga ndryshime te ardhshme te produktit)
  sasia       Decimal  @db.Decimal(10, 3)
  cmimiNjesi  Decimal  @db.Decimal(10, 2) // snapshot i cmimit ne kohen e shitjes
  nentotali   Decimal  @db.Decimal(10, 2)

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

// ------------------------------------------------------------
// PRINTERS CONFIG
// ------------------------------------------------------------

model Printer {
  id              String                 @id @default(uuid())
  emri            String
  lidhja          PrinterConnectionType  @default(USB)
  gjeresiaMM      Int                    @default(80) // 58 ose 80
  ipAdresa        String?                // per printera network
  porti           Int?                   @default(9100)
  pathUSB         String?                // per printera USB (p.sh. /dev/usb/lp0)
  aktiv           Boolean                @default(true)
  parazgjedhur    Boolean                @default(false)

  @@map("printers")
}

// ------------------------------------------------------------
// DAILY SNAPSHOTS (per raportin "stoku fillim/fund dite")
// ------------------------------------------------------------

model DailyStockSnapshot {
  id            String   @id @default(uuid())
  productId     String
  data          DateTime @db.Date

  sasiaFillim   Decimal  @db.Decimal(10, 3)
  sasiaFund     Decimal? @db.Decimal(10, 3) // mbushet ne fund te dites

  krijuarMe     DateTime @default(now())

  @@unique([productId, data])
  @@map("daily_stock_snapshots")
}

// ------------------------------------------------------------
// TAVOLINAT
// ------------------------------------------------------------
model Table {
  id        String   @id @default(uuid())
  numri     Int      @unique
  emri      String?  // p.sh. "VIP", "Ballkoni"
  kapaciteti Int     @default(4)
  pozicioniX Int     @default(0)
  pozicioniY Int     @default(0)
  aktiv     Boolean  @default(true)
  krijuarMe DateTime @default(now())

  @@map("tables")
}
